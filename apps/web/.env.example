# Frontend env — copy to apps/web/.env and fill in. NEVER commit the real .env.
# Both values are public (browser-exposed). Get them from the Supabase project
# (Project Settings > API) or ask Andrea.
#
# Spotify OAuth is configured in Supabase (Authentication > Providers > Spotify),
# NOT here — there is no VITE_SPOTIFY_* variable anymore.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
