# Spotify (frontend PKCE flow — CLIENT_ID is public, no secret needed in browser)
# Get the Client ID from your app at https://developer.spotify.com/dashboard
# IMPORTANT: Spotify requires loopback redirects to use 127.0.0.1, NOT localhost.
# In your Spotify app settings, add this Redirect URI EXACTLY:
#   http://127.0.0.1:5173/callback
VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback

# When Andrea's Express API is live, point here:
VITE_API_BASE_URL=http://127.0.0.1:4000
