# Copy this file to .env and fill in real values. NEVER commit .env.
# Get these from https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:55555/callback

# Backend — Neon Postgres (T01). Pooled URL for serverless; direct URL for migrations.
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.neon.tech/brink?sslmode=require
DIRECT_URL=postgresql://user:pass@ep-xxx.neon.tech/brink?sslmode=require

# Server-side session + token encryption (T02). Generate with: openssl rand -base64 32
SESSION_SECRET=
TOKEN_ENC_KEY=

# Set by Vercel Cron to authorize scheduled jobs (T21)
CRON_SECRET=
