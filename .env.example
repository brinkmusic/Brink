# Copy this file to .env and fill in real values. NEVER commit .env.

# --- Supabase Postgres ---
# From the Supabase dashboard -> Connect. The backend (SQLModel/psycopg) uses DATABASE_URL;
# Alembic migrations use DIRECT_URL.
# Pooled (6543) for the app; direct (5432) for migrations.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-x-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-x-region.pooler.supabase.com:5432/postgres

# --- Supabase Auth + Storage (T02 / T03 / T50) ---
# Backend (server-only — NEVER prefix with VITE_):
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY belong only in apps/web/.env.example —
# having them here causes drift. See apps/web/.env.example for those vars.
# SUPABASE_JWT_SECRET is intentionally absent: hard rule 6 says validate JWTs via
# getUser() (Supabase Admin SDK), never by checking the raw secret. Nothing in the
# codebase reads this variable; including it here would invite a real secret into a var
# that is never consumed (finding MI1, 2026-07-02 review).

# --- Spotify (server-side, to refresh stored provider tokens — T02 / T21) ---
# The Client ID/Secret are also entered in Supabase -> Auth -> Providers -> Spotify.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Encrypts the stored Spotify refresh token at rest (T02). Generate: openssl rand -base64 32
TOKEN_ENC_KEY=

# Authorizes the snapshot endpoint, called by the GitHub Actions cron (T21, ADR-0006)
CRON_SECRET=
